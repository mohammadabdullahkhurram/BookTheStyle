# -----------------------------------------------------------------------------
# PRODUCTION VALUES (Hostinger Cloud) — full walkthrough in docs/DEPLOY.md.
# Copy this file to .env on the server, run `php artisan key:generate`, and set:
#   APP_ENV=production
#   APP_DEBUG=false                       # never true in production
#   APP_URL=https://bookthestyle.com      # https — TLS terminates at the proxy
#   APP_DOMAIN=bookthestyle.com
#   SESSION_DOMAIN=.bookthestyle.com
#   SESSION_SECURE_COOKIE=true            # cookies over HTTPS only
#   LOG_LEVEL=warning
#   DB_*            → the Hostinger MySQL database credentials
#   MAIL_MAILER     → a real transport (temp passwords are login-critical)
#   QUEUE_CONNECTION=database             # drained by the per-minute cron
# Everything below defaults to LOCAL DEV values (lvh.me over plain http).
# -----------------------------------------------------------------------------

APP_NAME=BookTheStyle
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://lvh.me:8000

# Registrable apex domain. The platform is split four ways by host:
#   APP_DOMAIN              → public marketing landing (apex)
#   app.APP_DOMAIN          → the application: login/logout, account settings,
#                             agency console, salon picker (+ /cal, /webhooks)
#   register.APP_DOMAIN     → public "book a call" page (GHL calendar embed)
#   {slug}.APP_DOMAIN       → salon tenant subdomains
# Production: bookthestyle.com.
#
# Local dev uses lvh.me — a registrable domain whose wildcard DNS resolves
# lvh.me and *.lvh.me to 127.0.0.1 (no /etc/hosts edits, no tooling). We use it
# instead of *.localhost because browsers REFUSE to set a Domain cookie for
# localhost/*.localhost, so the login session can't be shared from app. to a
# salon subdomain there. lvh.me is a normal registrable domain, so SESSION_DOMAIN
# below works exactly like production. (localtest.me is an equivalent fallback.)
APP_DOMAIN=lvh.me

# Proxies to trust for the X-Forwarded-* headers (Cloudflare → Hostinger
# origin). '*' trusts whichever proxy connects — right while the origin only
# receives platform/Cloudflare traffic, and immune to Cloudflare range
# updates. To pin instead, set a comma-separated list of Cloudflare's
# published ranges (https://www.cloudflare.com/ips/). The real visitor IP is
# taken from CF-Connecting-IP either way (TrustCloudflareClientIp), so
# per-IP rate limits stay accurate behind the edge.
TRUSTED_PROXIES=*

# CSP frame-src allow-list for the register.{domain} book-a-call page ONLY, so a
# GoHighLevel / LeadConnector calendar iframe can be embedded. Every other host
# keeps frame-src 'self'. Confirm the exact embed origin when wiring the embed.
REGISTER_EMBED_FRAME_SRC="https://*.leadconnectorhq.com https://*.msgsndr.com"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

# Keep Livewire Blaze's compiler on, but its profiler/debug bar OFF: the bar
# pulls a webfont from fonts.googleapis.com, and this app is strictly self-hosted
# (no external font CDN). Leaving this false keeps pages CDN-free and CSP-clean.

# Password hashing. Argon2id is configured in config/hashing.php; this controls
# bcrypt cost only where bcrypt is used.
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Database — MySQL is the production target (Hostinger). For local dev/tests you
# may instead set DB_CONNECTION=sqlite (no other DB_* needed).
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bookthestyle
DB_USERNAME=bookthestyle
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Scope the session cookie to the parent domain (leading dot) so login on the
# apex carries to every salon subdomain. Must be a registrable domain — see the
# APP_DOMAIN note. Local: .lvh.me  Prod: .bookthestyle.com
SESSION_DOMAIN=.lvh.me
# Cookies stay HttpOnly (config default) + SameSite=lax (config default).
# Production: serve over HTTPS only and force secure cookies.
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Shared hosting has no always-on worker: the database queue is drained by a
# 1-minute cron (schedule:run -> queue:work --stop-when-empty). See SPEC §8.
QUEUE_CONNECTION=database

# Retention (rows pruned daily by the scheduler; shared hosting has a finite
# inode/disk budget). Defaults: 30 days of processed webhook events, 30 days
# (720 h) of failed jobs. Production tip: also set LOG_CHANNEL=daily so
# laravel.log rotates instead of growing forever.
# GHL_WEBHOOK_RETENTION_DAYS=30
# QUEUE_FAILED_RETENTION_HOURS=720

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Mail — BookTheStyle sends exactly ONE email type directly (the temporary
# password on user provisioning). Everything else (reminders, resets) routes
# through GoHighLevel. Configure a real transport in production.
# -----------------------------------------------------------------------------
# Transactional mail (account created, temp passwords, password reset, staff
# invites, salon added) is sent app-direct via Laravel Mail — never GHL.
# Local: MAIL_MAILER=log writes rendered emails to storage/logs/laravel.log.
#        For a real inbox UI, run Mailpit (https://mailpit.axllent.org):
#        MAIL_MAILER=smtp, MAIL_HOST=127.0.0.1, MAIL_PORT=1025 — view at
#        http://localhost:8025.
# Production (Phase 7): configure a REAL transport here (SMTP/SES/Resend/…)
#        before go-live — temporary passwords and password resets are
#        login-critical. Credentials live only in the server's .env.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@bookthestyle.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# GoHighLevel: there is NO global GHL key in this file. Each salon connects its
# own GHL sub-account; the Private Integration Token and webhook secret are
# stored per-salon in the database (salon_ghl_connections), ENCRYPTED AT REST.
# Nothing GHL-related belongs in .env.
# -----------------------------------------------------------------------------
