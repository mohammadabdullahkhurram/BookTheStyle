# NOTE: public/build/ (the Vite output) is deliberately COMMITTED — the
# Hostinger server has no Node, so deploys are: npm run build locally →
# commit → push → git pull on the server. See docs/DEPLOY.md.
/.phpunit.cache
/node_modules
/public/fonts-manifest.dev.json
/public/hot
/public/storage
/storage/*.key
/storage/pail
/vendor
.env
.env.backup
.env.production
.phpactor.json
.phpunit.result.cache
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log
/auth.json
/.fleet
/.idea
/.nova
/.vscode
/.zed

# Claude Code: keep shared project settings, ignore machine-local ones
/.claude/settings.local.json

# How-to documentation: keep the folder structure + posters, ignore heavy media.
# Videos are placed here locally for dev and uploaded to the same path on the
# server for prod — never committed.
/public/how-to-documentation/**/*.mp4
/public/how-to-documentation/**/*.mov
/public/how-to-documentation/**/*.webm

# Launch video — regenerable, never commit. (Contents-ignored rather than
# dir-ignored: git refuses to re-include a file inside an excluded DIRECTORY,
# so `assets/` + `!assets/.gitkeep` would silently drop the .gitkeep too.)
docs/launch-video/assets/*
!docs/launch-video/assets/.gitkeep
out/
*.mp4
*.mov

.DS_Store
